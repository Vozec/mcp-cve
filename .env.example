# NVD (National Vulnerability Database) - optional, increases rate limits
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# GitHub - optional, required for GitHub search tools
# https://github.com/settings/tokens (read:public_repo scope)
GITHUB_TOKEN=

# GitLab - optional, required for GitLab search tools
# https://gitlab.com/-/user_settings/personal_access_tokens (read_api scope)
GITLAB_TOKEN=

# Shodan - optional, required for recon/exposure data
# https://account.shodan.io
SHODAN_API_KEY=

# Vulners - optional, required for Vulners search
# https://vulners.com/userinfo
VULNERS_API_KEY=

# ProjectDiscovery - optional, required for Nuclei PoC search
# https://cloud.projectdiscovery.io/
PROJECTDISCOVERY_API_KEY=

# Redis - defaults to localhost if not set
REDIS_URL=redis://localhost:6379
